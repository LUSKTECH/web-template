{
  "name": "lusk-website-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src __tests__",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@sentry/nextjs": "10.48.0",
    "next": "16.2.2",
    "next-axiom": "1.10.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/compat": "^2.0.5",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-istanbul": "4.1.2",
    "eslint": "10.2.0",
    "eslint-config-next": "16.2.2",
    "fast-check": "4.6.0",
    "husky": "9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.2",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  },
  "overrides": {
    "serialize-javascript": "7.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
